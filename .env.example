# ─────────────────────────────────────────
#  A3B PLATFORM — Variables de Entorno
#  Copia este archivo como .env y completa
# ─────────────────────────────────────────

# APP
FRONTEND_URL=https://a3bhub.cloud
NEXT_PUBLIC_API_URL=https://api.a3bhub.cloud

# DATABASE
POSTGRES_USER=a3b_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=a3b_db
DATABASE_URL=postgresql://a3b_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/a3b_db

# REDIS
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# STRIPE
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# DEEPL
DEEPL_API_KEY=your_deepl_api_key

# EMAIL (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@a3bhub.cloud

# ADMIN
ADMIN_EMAIL=admin@a3bhub.cloud
